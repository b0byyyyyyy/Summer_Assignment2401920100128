
// sum of two array//
#include<iostream>
#include<vector>
class Solution {
public:
    vector<int> twoSum(vector<int>& nums, int target) {
        for(int i=0; i<nums.size(); ++i){
        for(int j=i+1; j<nums.size(); ++j)
        {
            if(nums[i]+nums[j] ==target){
                return{i,j};
            }

        }
        
    }
    return{};
    }
};

 //  remove duplicate from sorted array //

#include<iostream>
#include<vector>

class Solution{
public:
int removeDuplicates(vector<int> &nums){

int size= nums.size();
if(size<=1)
return size;

int i=0;

for(int j=1; j<size; ++j){
    if(nums[j] != nums[i]){
        nums[++i] = nums[j];
    }
}

return i+1;


}

};
